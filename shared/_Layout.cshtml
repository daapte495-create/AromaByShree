<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AromaByShree</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>

        @using Microsoft.AspNetCore.Http
        @inject IHttpContextAccessor HttpContextAccessor

        @if (HttpContextAccessor.HttpContext.Session.GetString("UserRole") == "Admin")
        {
            <ul>
            <li class="nav-item">
                <a class="nav-link text-warning fw-bold" asp-controller="Admin" asp-action="Dashboard">
                    <i class="bi bi-shield-lock"></i> ADMIN PANEL
                </a>
				</li>
			</ul>
        }
        else
        {
        }
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom py-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index" style="letter-spacing: 2px;">
                    AROMA BY SHREE
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Home" asp-action="About">About Us</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Home" asp-action="Contact">Contact</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Product" asp-action="Shop">Shop</a></li>
                    </ul>

                    <form class="d-flex me-lg-3 mb-3 mb-lg-0" asp-controller="Product" asp-action="Shop" method="get">
                        <div class="input-group">
                            <input type="text" name="search" class="form-control form-control-sm rounded-start-pill border-secondary bg-transparent text-white" placeholder="Search scent..." aria-label="Search">
                            <button class="btn btn-outline-light btn-sm rounded-end-pill" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="d-flex align-items-center flex-wrap gap-3 mt-3 mt-lg-0">
                        <a class="nav-link text-white p-0 position-relative" asp-controller="Product" asp-action="Wishlist">
                            <i class="bi bi-heart fs-5"></i>
                        </a>

                        <a class="nav-link text-white p-0 position-relative me-2" asp-controller="Product" asp-action="Cart">
                            <i class="bi bi-bag fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;">
                                @await Component.InvokeAsync("CartCount")
                            </span>
                        </a>

                        @* USER LOGIN / PROFILE SECTION *@
                        <div class="navbar-nav">
                            @if (Context.Session.GetString("UserName") != null)
                            {
                                <ul>
                                <li class="nav-item dropdown" style="list-style: none;">
                                    <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 fw-bold text-white" href="#" id="userDrop" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        @{
                                            var photoPath = Context.Session.GetString("UserProfilePhoto");
                                            var userName = Context.Session.GetString("UserName");
                                        }

                                        @if (!string.IsNullOrEmpty(photoPath) && photoPath != "default-user.png")
                                        {
                                                <img src="@Url.Content("~/images/profiles/" + (Context.Session.GetString("UserProfilePhoto") ?? "default-user.png"))"
                                                     class="rounded-circle" style="width:30px; height:30px; object-fit:cover;">
                                        }
                                        else
                                        {
                                            <span class="bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center"
                                                  style="width: 35px; height: 35px; font-size: 0.8rem; border: 1px solid white;">
                                                @(userName?.Length > 0 ? userName.Substring(0, 1).ToUpper() : "U")
                                            </span>
                                        }
                                        <span class="d-none d-md-inline">@userName</span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow rounded-3 mt-2">
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="Account" asp-action="Dashboard">
                                                <i class="bi bi-speedometer2 me-2"></i> My Dashboard
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2" asp-controller="Account" asp-action="Dashboard">
                                                <i class="bi bi-bag-check me-2"></i> My Orders
                                            </a>
                                                <a class="dropdown-item py-2" asp-controller="Account" asp-action="EditProfile">
                                                    <i class="bi bi-bag-check me-2"></i>Settings
                                                </a>
                                          
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout">
                                                <i class="bi bi-box-arrow-right me-2"></i> Logout
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                                </ul>
                            }
                            else
                            {
                                <a class="btn btn-outline-light btn-sm rounded-pill px-3 fw-bold" asp-controller="Account" asp-action="Login">
                                    LOGIN
                                </a>
                                <a class="btn btn-warning btn-sm rounded-pill px-3 fw-bold text-dark" asp-controller="Account" asp-action="Register">
                                    REGISTER
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white pt-5 pb-4 mt-5 border-top border-secondary">
        <div class="container text-center text-md-left">
            <div class="row">
                <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">AromaByShree</h5>
                    <p>Luxury scents crafted for elegance. Discover your signature fragrance with us.</p>
                </div>
                <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Products</h5>
                    <p><a asp-controller="Product" asp-action="Shop" asp-route-gender="Men" class="text-white text-decoration-none">Mens</a></p>
                    <p><a asp-controller="Product" asp-action="Shop" asp-route-gender="Women" class="text-white text-decoration-none">Womens</a></p>
                    <p><a asp-controller="Product" asp-action="Shop" class="text-white text-decoration-none">All Collections</a></p>
                </div>
                <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mt-3">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Useful Links</h5>
                    <p><a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none">Home</a></p>
                    <p><a asp-controller="Home" asp-action="About" class="text-white text-decoration-none">About Us</a></p>
                    <p><a asp-controller="Home" asp-action="Contact" class="text-white text-decoration-none">Contact Us</a></p>
                </div>
                <div class="col-md-4 col-lg-3 col-xl-3 mx-auto mt-3 text-md-start">
                    <h5 class="text-uppercase mb-4 font-weight-bold text-warning">Contact</h5>
                    <p><i class="bi bi-geo-alt-fill me-2"></i> Rajkot, Gujarat, India</p>
                    <p><i class="bi bi-envelope-fill me-2"></i> info@shreeperfume.com</p>
                    <p><i class="bi bi-telephone-fill me-2"></i> +91 98765 43210</p>
                </div>
            </div>
            <hr class="mb-4">
            <div class="row align-items-center">
                <div class="col-md-12 text-center">
                    <p>© 2026 Copyright: <strong class="text-warning">Shree Perfume</strong> | All Rights Reserved</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
