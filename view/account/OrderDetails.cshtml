@model ShreePerfume.Models.Order
@{
    var items = ViewBag.OrderItems as List<ShreePerfume.Models.OrderItem> ?? new List<ShreePerfume.Models.OrderItem>();
    var perfumes = ViewBag.Perfumes as List<ShreePerfume.Models.Perfume> ?? new List<ShreePerfume.Models.Perfume>();
}

<div class="container my-5 py-5">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-dark text-white p-4">
            <h3 class="mb-0">Order Summary #@Model.Id</h3>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            
                            var p = perfumes.FirstOrDefault(x => x.Id == item.ProductId);
                            <tr>
                                <td>@p?.Name</td>
                                <td>@item.Quantity</td>
                                <td>₹@item.Price</td>
                                <td>₹@(item.Quantity* item.Price)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-end mt-4">
                <h4>Total Amount: <span class="text-success">₹@Model.TotalAmount</span></h4>
                <p class="text-muted small">Status: @Model.Status</p>
            </div>
        </div>
    </div>
</div>