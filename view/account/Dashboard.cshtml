@model IEnumerable<ShreePerfume.Models.Order>

<div class="container my-5 py-5">
    <div class="row">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-4 rounded-4 text-center bg-light">
                <div class="mb-3">
                    @{
                        var userPhoto = Context.Session.GetString("UserProfilePhoto") ?? "default-user.png";
                    }
                    <img src="@Url.Content("~/images/profiles/" + userPhoto)"
                         class="rounded-circle shadow-sm border border-3 border-white"
                         style="width: 100px; height: 100px; object-fit: cover;" alt="Profile">
                </div>

                <h5 class="fw-bold mb-0">@Context.Session.GetString("UserName")</h5>
                <p class="text-muted small">Customer Dashboard</p>

                <hr class="my-3">

                <div class="d-grid gap-2">
                    <a asp-action="Dashboard" class="btn btn-dark btn-sm rounded-pill text-start ps-3">
                        <i class="bi bi-bag-check me-2"></i> My Orders
                    </a>
                    <a asp-action="EditProfile" class="btn btn-outline-dark btn-sm rounded-pill text-start ps-3 border-0">
                        <i class="bi bi-person-gear me-2"></i> Edit Profile
                    </a>
                    <a asp-action="Logout" class="btn btn-outline-danger btn-sm rounded-pill text-start ps-3 border-0 mt-2">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            <h2 class="fw-bold mb-4" style="font-family: 'Playfair Display', serif;">My Order History</h2>

            @if (!Model.Any())
            {
                <div class="alert alert-info rounded-4 p-5 text-center border-0 shadow-sm">
                    <p class="mb-3 fs-5">You haven't placed any orders yet.</p>
                    <a asp-controller="Product" asp-action="Shop" class="btn btn-dark rounded-pill px-4">Start Shopping</a>
                </div>
            }
            else
            {
                <div class="table-responsive shadow-sm rounded-4 border bg-white">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th class="ps-4 py-3">Order ID</th>
                                <th>Date</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th class="text-end pe-4">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">#@order.Id</td>
                                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td class="fw-bold text-success">₹@order.TotalAmount.ToString("N0")</td>
                                    <td>
                                        @{
                                            var statusClass = order.Status switch
                                            {
                                                "Pending" => "bg-warning text-dark",
                                                "Shipped" => "bg-info text-white",
                                                "Delivered" => "bg-success text-white",
                                                "Cancelled" => "bg-danger text-white",
                                                _ => "bg-secondary text-white"
                                            };
                                        }
                                        <span class="badge @statusClass rounded-pill px-3 py-2" style="font-size: 0.75rem;">
                                            @order.Status
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Account" asp-action="OrderDetails" asp-route-id="@order.Id"
                                           class="btn btn-sm btn-outline-dark rounded-pill px-3">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<h3 class="fw-bold mt-5 mb-4">My Inquiries & Support</h3>
<div class="row">
    @if (ViewBag.Inquiries != null)
    {
        @foreach (var inq in (List<ShreePerfume.Models.ContactForm>)ViewBag.Inquiries)
        {
            <div class="col-md-6 mb-3">
                <div class="card border-0 shadow-sm rounded-4 p-3">
                    <p><strong>Question:</strong> @inq.Message</p>
                    @if (!string.IsNullOrEmpty(inq.AdminReply))
                    {
                        <p class="text-primary"><strong>Answer/Admin Reply:</strong> @inq.AdminReply</p>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p class="ps-3 text-muted">No inquiries found.</p>
    }
</div>