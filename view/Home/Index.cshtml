@model IEnumerable<ShreePerfume.Models.Perfume>

@{
    ViewData["Title"] = "Home - Aroma by Shree";
}

<div class="container-fluid p-0">
    <div class="position-relative text-center shadow-sm overflow-hidden"
         style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/perfume-hero-bg.jpg');
                background-size: cover;
                background-position: center;
                min-height: 70vh;
                display: flex;
                align-items: center;
                justify-content: center;">

        <div class="text-white px-3 animate__animated animate__fadeIn">
            <h1 class="display-2 fw-bold mb-3" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">AROMA BY SHREE</h1>
            <p class="lead mb-4 fs-4 fw-light">Discover the Art of Fine Fragrance</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/Product/Shop" class="btn btn-warning btn-lg px-5 py-3 rounded-pill fw-bold text-dark shadow">SHOP COLLECTION</a>
                <a asp-controller="Home" asp-action="About" class="btn btn-outline-light btn-lg px-5 py-3 rounded-pill fw-bold">OUR STORY</a>
            </div>
        </div>
    </div>
</div>

<div class="container my-5 py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold" style="font-family: 'Playfair Display', serif;">Curated For You</h2>
        <div class="mx-auto bg-warning" style="height: 3px; width: 60px;"></div>
    </div>
    <div class="row g-4">

        <div class="col-md-6 animate__animated animate__fadeInLeft">
            <div class="position-relative overflow-hidden rounded-4 shadow-sm category-card" style="height: 450px;">
                <img src="/images/him.jpg" class="w-100 h-100 object-fit-cover transition-img" style="position: absolute; top:0; left:0; z-index: 1;">

                <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex align-items-center justify-content-center" style="z-index: 2;">
                    <div class="text-center px-3">
                        <h2 class="text-white fw-bold display-5 mb-3">FOR HIM</h2>
                        <a asp-controller="Product" asp-action="Shop" asp-route-gender="Men" class="btn btn-light rounded-pill px-4 fw-bold shadow-sm">BROWSE MENS</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 animate__animated animate__fadeInRight">
            <div class="position-relative overflow-hidden rounded-4 shadow-sm category-card" style="height: 450px;">
                <img src="/images/her1.jpg" class="w-100 h-100 object-fit-cover transition-img" style="position: absolute; top:0; left:0; z-index: 1;">

                <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex align-items-center justify-content-center" style="z-index: 2;">
                    <div class="text-center px-3">
                        <h2 class="text-white fw-bold display-5 mb-3">FOR HER</h2>
                        <a asp-controller="Product" asp-action="Shop" asp-route-gender="Women" class="btn btn-light rounded-pill px-4 fw-bold shadow-sm">BROWSE WOMENS</a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="bg-light py-5">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-md-4">
                <div class="p-4">
                    <i class="bi bi-droplet-half text-warning display-4 mb-3"></i>
                    <h5 class="fw-bold">Pure Essence</h5>
                    <p class="text-muted small">We use 100% natural essential oils for a richer, more authentic scent profile.</p>
                </div>
            </div>
            <div class="col-md-4 border-start border-end border-md-none">
                <div class="p-4">
                    <i class="bi bi-clock-history text-warning display-4 mb-3"></i>
                    <h5 class="fw-bold">12+ Hour Wear</h5>
                    <p class="text-muted small">Our high-concentration Parfum ensures your signature scent stays with you.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4">
                    <i class="bi bi-gift text-warning display-4 mb-3"></i>
                    <h5 class="fw-bold">Luxury Gifting</h5>
                    <p class="text-muted small">Every order arrives in our signature premium velvet-lined box packaging.</p>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="container my-5 py-5">
    <div class="row align-items-center">
        <div class="col-md-5 animate__animated animate__fadeInLeft">
            <h2 class="display-5 fw-bold mb-4" style="font-family: 'Playfair Display', serif;">The Art of Extraction</h2>
            <p class="lead text-muted">From the heart of Rajkot, we bring you fragrances crafted with ancient techniques and modern precision.</p>
            <ul class="list-unstyled">
                <li class="mb-3"><i class="bi bi-check2-circle text-warning me-2"></i> Hand-picked seasonal ingredients</li>
                <li class="mb-3"><i class="bi bi-check2-circle text-warning me-2"></i> 6-month aging process for depth</li>
                <li class="mb-3"><i class="bi bi-check2-circle text-warning me-2"></i> Small-batch production</li>
            </ul>
        </div>
        <div class="col-md-7 animate__animated animate__fadeInRight">
            <div class="row g-3">
                <div class="col-6">
                    <img src="/images/Ingredients.jpg" class="img-fluid rounded-4 shadow-sm" alt="Ingredients">
                </div>
                <div class="col-6 mt-5">
                    <img src="/images/Bottling1.jpg" class="img-fluid rounded-4 shadow-sm" alt="Bottling">
                </div>
            </div>
        </div>
    </div>
</div>


<div class="bg-light py-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-5" style="font-family: 'Playfair Display', serif;">Wear the Moment</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 bg-transparent h-100">
                    <div class="rounded-circle bg-white shadow-sm mx-auto d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
					 <img src="/images/DailyOffice.jpg" class="w-100 h-100 object-fit-cover" alt="Office">
                    </div>
                    <div class="card-body">
                        <h5 class="fw-bold">Daily Office</h5>
                       
                        <p class="small text-muted">Subtle, clean, and professional scents.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-transparent h-100">
                    <div class="rounded-circle bg-white shadow-sm mx-auto d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
						 <img src="/images/SpecialEvents.jpg" class="w-100 h-100 object-fit-cover" alt="Office" />
                    </div>
                    <div class="card-body">
                        <h5 class="fw-bold">Professional Edge</h5>
                  
                        <p class="small text-muted">Clean, crisp, and commanding respect.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-transparent h-100">
                    <div class="rounded-circle bg-white shadow-sm mx-auto d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
					 <img src="/images/SpecialEvents1.jpg" class="w-100 h-100 object-fit-cover" alt="Office">
                    </div>
                    <div class="card-body">
                        <h5 class="fw-bold">Special Events</h5>
                      
                        <p class="small text-muted">Bold, long-lasting luxury fragrances.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

