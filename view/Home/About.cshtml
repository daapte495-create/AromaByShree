@{
    ViewData["Title"] = "About Us - Shree Perfume";
}

<style>
    .about-header-new {
        /* Beautiful Background Image */
        background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('/images/about.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed; /* Creates a sophisticated parallax effect */
        /* Layout & Spacing */
        color: white;
        padding: 120px 0;
        text-align: center;
        margin-top: -1.5rem; /* Removes unwanted gap below the navbar */
        position: relative;
    }

    .shree-about-title {
        font-family: 'Playfair Display', serif; /* Elegant, luxury font */
        font-weight: 700;
        letter-spacing: 10px; /* Expansive, "vogue" letter spacing */
        text-transform: uppercase;
        margin-bottom: 25px;
    }

    .shree-about-subtitle {
        font-style: italic;
        letter-spacing: 2px;
        color: rgba(255, 255, 255, 0.8); /* Elegant, slightly translucent color */
    }

    /* Beautiful, glowing gold divider line */
    .shree-gold-line {
        width: 100px;
        height: 2px;
        background: linear-gradient(90deg, transparent, #d4af37, transparent);
        margin: 25px auto;
        box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
    }
</style>

<div class="about-header-new shadow-lg animate__animated animate__fadeIn">
    <div class="container">
        <h1 class="display-3 shree-about-title text-white">Our Story</h1>
        <div class="shree-gold-line"></div>
        <p class="h5 shree-about-subtitle">Crafting timeless scents since 2024</p>
    </div>
</div>

<div class="container my-5 py-5 story-section">
    <div class="row align-items-center">
        <div class="col-md-6 mb-4">
            <img src="~/images/store1.jpg" class="img-fluid rounded shadow" alt="Perfume Lab">
        </div>
        <div class="col-md-6 px-lg-5">
            <h2 class="fw-bold mb-4">The Essence of Shree Perfume</h2>
            <p>
                At <strong>Shree Perfume</strong>, we believe that a fragrance is more than just a scent—it is a memory, an emotion, and a signature of your personality.
                Our journey began with a simple mission: to bring the luxury of world-class perfumery to your doorstep.
            </p>
            <p>
                Every bottle is a result of months of research, sourcing the finest ingredients from around the globe, from the roses of Bulgaria to the deep Oud of the East.
            </p>
            <div class="mt-4">
                <h5 class="fw-bold text-dark"><i class="bi bi-check-circle-fill text-success me-2"></i> 100% Pure Essential Oils</h5>
                <h5 class="fw-bold text-dark"><i class="bi bi-check-circle-fill text-success me-2"></i> Long-lasting Fragrance</h5>
                <h5 class="fw-bold text-dark"><i class="bi bi-check-circle-fill text-success me-2"></i> Cruelty-Free</h5>
            </div>
        </div>
    </div>
</div>

<div class="bg-light py-5">
    <div class="container text-center">
        <h2 class="mb-5 fw-bold">Why Choose Us?</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="p-4 bg-white shadow-sm h-100">
                    <h1 class="display-4 text-warning"><i class="bi bi-gem"></i></h1>
                    <h4 class="fw-bold">Premium Quality</h4>
                    <p class="text-muted small">We never compromise on the quality of our ingredients.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="p-4 bg-white shadow-sm h-100">
                    <h1 class="display-4 text-warning"><i class="bi bi-truck"></i></h1>
                    <h4 class="fw-bold">Fast Delivery</h4>
                    <p class="text-muted small">Experience luxury delivered to your home within 3-5 days.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="p-4 bg-white shadow-sm h-100">
                    <h1 class="display-4 text-warning"><i class="bi bi-heart-fill"></i></h1>
                    <h4 class="fw-bold">Customer First</h4>
                    <p class="text-muted small">Your satisfaction is our ultimate goal.</p>
                </div>
            </div>
        </div>
    </div>
</div>