@* ordersuccess.cshtml file *@

<div class="container my-5 py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
            </div>
            <h1 class="display-5 fw-bold mb-3" style="font-family: 'Playfair Display', serif;">Thank You for Your Order!</h1>
            <p class="text-muted fs-5 mb-5">Your fragrance is being prepared. We will notify you once it's out for delivery. Get ready to wear the moment!</p>

            <div class="card border-0 shadow-sm p-4 bg-light mb-5">
                <h6 class="text-uppercase small fw-bold text-muted mb-3">Order Summary</h6>
                <p class="mb-1">Payment Mode: <strong>Cash on Delivery</strong></p>
                <p class="mb-0">Estimated Delivery: <strong>3-5 Business Days</strong></p>
            </div>

            <a asp-action="Shop" class="btn btn-dark rounded-pill px-5 py-3 fw-bold">
                CONTINUE SHOPPING
            </a>
        </div>
    </div>
</div>