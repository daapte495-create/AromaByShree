@* Views/Product/cart.cshtml file *@

@model List<ShreePerfume.Models.CartItem>

<div class="container my-5 py-5">
    <h2 class="fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Your Fragrance Bag</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">Your bag is empty.</p>
            <a asp-action="Shop" class="btn btn-dark rounded-pill px-4">Continue Shopping</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                @foreach (var item in Model)
                {
                    <div class="d-flex align-items-center border-bottom py-3">
                        <img src="@item.ImageUrl" style="width: 80px; height: 80px; object-fit: cover;" class="rounded shadow-sm">

                        <div class="ms-3 flex-grow-1">
                            <h6 class="fw-bold mb-1">@item.ProductName</h6>

                            <div class="d-flex align-items-center mb-2">
                                <a asp-action="UpdateQuantity" asp-route-id="@item.ProductId" asp-route-amount="-1"
                                   class="btn btn-sm btn-outline-secondary py-0 px-2 fw-bold">-</a>

                                <span class="mx-3 fw-bold">@item.Quantity</span>

                                <a asp-action="UpdateQuantity" asp-route-id="@item.ProductId" asp-route-amount="1"
                                   class="btn btn-sm btn-outline-secondary py-0 px-2 fw-bold">+</a>
                            </div>

                            <a asp-action="RemoveFromCart" asp-route-id="@item.ProductId" class="text-danger small text-decoration-none">
                                <i class="bi bi-trash"></i> Remove
                            </a>
                        </div>

                        <div class="text-end">
                            <p class="fw-bold mb-0">₹@(item.Price* item.Quantity)</p>
                        </div>
                    </div>
                }
            </div>

            <div class="mb-3">
                <a asp-action="Shop" class="btn btn-outline-dark w-100 rounded-pill fw-bold py-2">
                    <i class="bi bi-arrow-left"></i> CONTINUE SHOPPING
                </a>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 bg-light">
                    <h5 class="fw-bold mb-3">Summary</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>₹@Model.Sum(x => x.Price * x.Quantity)</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span>Shipping</span>
                        <span class="text-success">FREE</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold">Total</span>
                        <span class="fw-bold fs-5">₹@Model.Sum(x => x.Price * x.Quantity)</span>
                    </div>
                    <a asp-action="Shipping" class="btn btn-warning w-100 rounded-pill fw-bold py-3 text-white">PROCEED TO SHIPPING</a>
                </div>
            </div>
        </div>
    }
</div>