@{
    Layout = null; // Taaki user-side ka navbar yahan na dikhe
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #1a1a1a;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .login-box {
            background: #2d2d2d;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            width: 400px;
        }

        .btn-admin {
            background: #d4af37;
            color: black;
            font-weight: bold;
            border: none;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <h3 class="text-center mb-4">AromaByShree's <br /><small>Admin Access</small></h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="AdminLogin" method="post">
            <div class="mb-3">
                <label>Admin Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <div class="mb-3">
                <label>Password</label>
                <input type="password" name="password" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-admin w-100">Login to Dashboard</button>
        </form>
    </div>
</body>
</html>