@model IEnumerable<ShreePerfume.Models.Review>
@{
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">

        <div class="mb-4">
        <a asp-action="Dashboard" class="back-link text-decoration-none text-dark fw-bold">
            <i class="bi bi-arrow-left me-2"></i> Back 
        </a>
    </div>

    <h3 class="fw-bold mb-4">Product Reviews & Ratings</h3>

    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold text-primary">@item.UserName</span>
                            <small class="text-muted">@item.Date.ToString("dd MMM yyyy")</small>
                        </div>

                        <div class="mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= item.Rating)
                                {
                                    <i class="bi bi-star-fill text-warning"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star text-muted"></i>
                                }
                            }
                            <span class="ms-1 small fw-bold">(@item.Rating/5)</span>
                        </div>

                        <p class="card-text text-secondary italic small">"@item.Comment"</p>

                        <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
                            <span class="small text-muted">Product ID: #@item.ProductId</span>
                            <a asp-action="DeleteReview" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger rounded-pill"
                               onclick="return confirm('Delete this review?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>

    .back-link {
        display: inline-flex;
        align-items: center;
        transition: all 0.3s ease;
        position: relative;
    }

        .back-link:hover {
            color: #ffc107 !important;
            transform: translateX(-5px);
        }

        .back-link i {
            transition: transform 0.3s ease;
        }

        .back-link:hover i {
            transform: scale(1.2);
        }

        .back-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #ffc107;
            transition: width 0.3s ease;
        }

        .back-link:hover::after {
            width: 100%;
        }
</style>