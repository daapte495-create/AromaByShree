@model IEnumerable<ShreePerfume.Models.Order>
@{
    Layout = "_AdminLayout";
}


<div class="mb-4">
    <a asp-action="Dashboard" class="back-link text-decoration-none text-dark fw-bold">
        <i class="bi bi-arrow-left me-2"></i> Back
    </a>
</div>

<h2 class="fw-bold mb-4">Customer Orders</h2>

<div class="card shadow-sm border-0 rounded-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Order ID</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">#@item.Id</td>
                        <td>
                            @item.User?.FullName <br>
                            <small class="text-muted">@item.User?.Email</small>
                        </td>
                        <td>@item.OrderDate.ToString("dd MMM yyyy")</td>
                        <td class="text-primary fw-bold">₹@item.TotalAmount</td>
                        <td>
                            <form asp-action="UpdateOrderStatus" method="post" class="d-flex align-items-center gap-2">
                                <input type="hidden" name="id" value="@item.Id" />

                                <select name="status" onchange="this.form.submit()"
                                        class="form-select form-select-sm rounded-pill border-0 shadow-sm"
                                        style="width: 130px; cursor: pointer; background-color: #f8f9fa;">

                                    <option value="Processing" selected='@(item.Status == "Processing")'>Processing</option>
                                    <option value="Shipped" selected='@(item.Status == "Shipped")'>Shipped</option>
                                    <option value="Delivered" selected='@(item.Status == "Delivered")'>Delivered</option>
                                    <option value="Cancelled" selected='@(item.Status == "Cancelled")'>Cancelled</option>
                                </select>

                                @if (item.Status == "Delivered")
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>

    .back-link {
        display: inline-flex;
        align-items: center;
        transition: all 0.3s ease;
        position: relative;
    }

        .back-link:hover {
            color: #ffc107 !important;
            transform: translateX(-5px);
        }

        .back-link i {
            transition: transform 0.3s ease;
        }

        .back-link:hover i {
            transform: scale(1.2);
        }

        .back-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #ffc107;
            transition: width 0.3s ease;
        }

        .back-link:hover::after {
            width: 100%;
        }
</style>