@model IEnumerable<ShreePerfume.Models.Perfume>
@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">

    <div class="mb-4">
        <a asp-action="Dashboard" class="back-link text-decoration-none text-dark fw-bold">
            <i class="bi bi-arrow-left me-2"></i> Back 
        </a>
    </div>

    <h2 class="fw-bold">Inventory Management</h2>
    <a asp-action="AddProduct" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-plus-lg"></i> Add New Perfume
    </a>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@item.ImageUrl"
                                         class="rounded-3 me-3"
                                         width="50" height="50"
                                         style="object-fit: cover;"
                                         onerror="this.src='/images/perfume.jpg';" /> <div>
                                        <div class="fw-bold">@item.Name</div>
                                        <small class="text-muted text-truncate" style="max-width: 150px; display: block;">@item.Description</small>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-dark border">@item.Gender</span></td>
                            <td class="fw-bold">₹@item.Price</td>
                            <td><span class="text-success small"><i class="bi bi-check-circle-fill"></i> In Stock</span></td>
                            <td class="text-center">
                                <a asp-action="EditProduct" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="DeleteProduct" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .back-link {
        display: inline-flex;
        align-items: center;
        transition: all 0.3s ease;
        position: relative;
    }

        .back-link:hover {
            color: #ffc107 !important;
            transform: translateX(-5px);
        }

        .back-link i {
            transition: transform 0.3s ease;
        }

        .back-link:hover i {
            transform: scale(1.2);
        }

        .back-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #ffc107;
            transition: width 0.3s ease;
        }

        .back-link:hover::after {
            width: 100%;
        }
</style>