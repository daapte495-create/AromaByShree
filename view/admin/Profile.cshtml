@model ShreePerfume.Models.User
@{
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h3 class="fw-bold text-center mb-4">Admin Settings</h3>
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                <form asp-action="UpdateProfile" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Full Name</label>
                        <input type="text" name="fullName" value="@Model.FullName" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input type="email" name="email" value="@Model.Email" class="form-control">
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">New Password</label>
                        <input type="password" name="newPassword" class="form-control" placeholder="Leave blank to keep current">
                    </div>
                    <button type="submit" class="btn btn-dark w-100 py-2 rounded-pill">Save Profile</button>
                </form>
            </div>
        </div>
    </div>
</div>