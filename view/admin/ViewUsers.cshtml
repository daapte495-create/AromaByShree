@model IEnumerable<ShreePerfume.Models.User>
@{
    Layout = "_AdminLayout";
}

<div class="mb-4">
    <a asp-action="Dashboard" class="back-link text-decoration-none text-dark fw-bold">
        <i class="bi bi-arrow-left me-2"></i> Back
    </a>
</div>

<h2 class="fw-bold mb-4">Registered Customers</h2>

<div class="card shadow-sm border-0 rounded-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">User Details</th>
                    <th>Email</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold">@user.FullName</div>
                        </td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-light text-dark border">@user.Role</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>

    .back-link {
        display: inline-flex;
        align-items: center;
        transition: all 0.3s ease;
        position: relative;
    }

        .back-link:hover {
            color: #ffc107 !important;
            transform: translateX(-5px);
        }

        .back-link i {
            transition: transform 0.3s ease;
        }

        .back-link:hover i {
            transform: scale(1.2);
        }

        .back-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #ffc107;
            transition: width 0.3s ease;
        }

        .back-link:hover::after {
            width: 100%;
        }
</style>